---
import type { CollectionEntry } from 'astro:content';
import { formatDate } from '@lib/archive';
import MetaLine from '@components/meta/MetaLine.astro';
import ObjectNumber from '@components/meta/ObjectNumber.astro';
import StatusLabel from '@components/meta/StatusLabel.astro';
import TypeLabel from '@components/meta/TypeLabel.astro';

interface Props {
  object: CollectionEntry<'archive'>;
}

const { object } = Astro.props;
const data = object.data;
const href = `/archive/${object.id}`;
const updated = data.updated ?? data.date;
const objectNumber = data.objectId ?? object.id;
---

<article class="compact-object-row" data-type={data.type}>
  <a href={href} aria-label={`Read ${data.title}`}>
    <div class="compact-meta">
      <ObjectNumber value={objectNumber} />
      <TypeLabel type={data.type} />
    </div>
    <h3>{data.title}</h3>
    <div class="compact-status">
      <StatusLabel status={data.status} />
      <time datetime={updated.toISOString()}>{formatDate(updated)}</time>
    </div>
  </a>
</article>

<style>
  .compact-object-row {
    --object-accent: var(--color-accent);
    border-top: 1px solid var(--color-border-soft);
    position: relative;
    transition:
      background var(--motion-fast),
      border-color var(--motion-fast);
  }

  .compact-object-row::before {
    background: var(--object-accent);
    content: '';
    height: calc(100% - 0.7rem);
    left: 0;
    opacity: 0;
    position: absolute;
    top: 0.35rem;
    width: 1px;
  }

  .compact-object-row:hover,
  .compact-object-row:focus-within {
    background: rgba(255, 255, 255, 0.018);
    border-color: var(--color-border);
  }

  .compact-object-row:hover::before,
  .compact-object-row:focus-within::before {
    opacity: 0.72;
  }

  .compact-object-row[data-type='essay'] {
    --object-accent: var(--type-essay);
  }

  .compact-object-row[data-type='research'] {
    --object-accent: var(--type-research);
  }

  .compact-object-row[data-type='system'] {
    --object-accent: var(--type-system);
  }

  .compact-object-row[data-type='signal'] {
    --object-accent: var(--type-signal);
  }

  .compact-object-row[data-type='project'] {
    --object-accent: var(--type-project);
  }

  .compact-object-row[data-type='failure'] {
    --object-accent: var(--type-failure);
  }

  .compact-object-row[data-type='experiment'] {
    --object-accent: var(--type-experiment);
  }

  .compact-object-row[data-type='journal'] {
    --object-accent: var(--type-journal);
  }

  a {
    display: grid;
    gap: 0.62rem;
    padding: 0.95rem 0.75rem 1rem 0.9rem;
  }

  a:focus-visible {
    outline: 1px solid var(--object-accent);
    outline-offset: 3px;
  }

  .compact-meta {
    align-items: center;
    color: var(--color-meta);
    display: flex;
    flex-wrap: wrap;
    font-family: var(--font-mono);
    font-size: var(--text-meta);
    gap: 0.5rem;
    letter-spacing: var(--tracking-meta);
    min-width: 0;
    text-transform: uppercase;
  }

  h3 {
    font-size: 0.96rem;
    line-height: 1.35;
    margin: 0;
    min-width: 0;
    overflow-wrap: break-word;
    word-break: normal;
  }

  .compact-status {
    align-items: center;
    color: var(--color-meta);
    display: flex;
    flex-wrap: wrap;
    font-family: var(--font-mono);
    font-size: var(--text-meta);
    gap: 0.5rem;
    letter-spacing: var(--tracking-meta);
    text-transform: uppercase;
  }

  .compact-status time {
    color: var(--color-meta);
    white-space: nowrap;
  }
</style>
