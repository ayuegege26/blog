---
const navItems = [
  { href: '/', label: 'Observatory' },
  { href: '/archive', label: 'Archive' },
  { href: '/projects', label: 'Projects' },
  { href: '/essays', label: 'Essays' },
  { href: '/about', label: 'About' },
  { href: '/lab', label: 'Lab' },
];
---

<header class="site-header">
  <a class="brand" href="/" aria-label="Ayue Observatory 首页">
    <span class="brand-mark">AO</span>
    <span>Ayue Observatory</span>
  </a>
  <nav aria-label="主导航">
    {navItems.map((item) => <a href={item.href}>{item.label}</a>)}
  </nav>
</header>

<style>
  .site-header {
    width: min(100% - 32px, var(--layout-max));
    margin: 0 auto;
    padding: 1.4rem 0;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1rem;
    border-bottom: 1px solid var(--color-border-soft);
  }

  .brand {
    display: inline-flex;
    align-items: center;
    gap: 0.7rem;
    font-family: var(--font-mono);
    font-size: 0.88rem;
    color: var(--color-text);
  }

  .brand-mark {
    display: inline-grid;
    width: 2rem;
    height: 2rem;
    place-items: center;
    border: 1px solid var(--color-border);
    border-radius: 50%;
    color: var(--color-accent);
  }

  nav {
    display: flex;
    flex-wrap: wrap;
    gap: 0.9rem;
    color: var(--color-text-muted);
    font-family: var(--font-mono);
    font-size: 0.82rem;
  }

  @media (max-width: 720px) {
    .site-header {
      align-items: flex-start;
      flex-direction: column;
    }
  }
</style>
