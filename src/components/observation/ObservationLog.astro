---
import ObservationEntry from '@components/observation/ObservationEntry.astro';

interface Entry {
  label: string;
  text: string;
  stamp?: string;
  href?: string;
}

interface Props {
  label?: string;
  period?: string;
  entries: Entry[];
  note?: string;
}

const { label = '观测记录', period, entries, note } = Astro.props;
---

<aside class="observation-log" aria-label={label}>
  <header>
    <span>{label}</span>
    {period && <time>{period}</time>}
  </header>
  <div class="entry-list">
    {entries.map((entry) => <ObservationEntry {...entry} />)}
  </div>
  {note && <p class="log-note">{note}</p>}
</aside>

<style>
  .observation-log {
    background: rgba(17, 21, 27, 0.78);
    border: 1px solid var(--color-border-soft);
    border-radius: var(--radius-card);
    padding: 1rem;
  }

  header {
    align-items: center;
    color: var(--color-accent);
    display: flex;
    flex-wrap: wrap;
    font-family: var(--font-mono);
    font-size: var(--text-meta);
    gap: 0.75rem;
    justify-content: space-between;
    letter-spacing: var(--tracking-meta);
    padding-bottom: 0.75rem;
    text-transform: uppercase;
  }

  header time {
    color: var(--color-meta);
  }

  .entry-list {
    display: grid;
  }

  .log-note {
    border-top: 1px solid var(--color-border-soft);
    color: var(--color-text-faint);
    font-family: var(--font-mono);
    font-size: var(--text-meta);
    letter-spacing: var(--tracking-meta);
    margin: 0;
    padding-top: 0.85rem;
    text-transform: uppercase;
  }
</style>
