---
import type { ArchiveAtlasNode } from '../../lab/data/archive-atlas';

interface Props { nodes: ArchiveAtlasNode[]; }
const { nodes } = Astro.props;

const typeLabels = {
  essay: '隨筆', research: '研究', system: '系統', signal: '信號', project: '項目',
  failure: '復盤', experiment: '實驗', journal: '記錄', unknown: '未知',
};
const fieldLabels = {
  research: 'RESEARCH', systems: 'SYSTEMS', signals: 'SIGNALS', essays: 'ESSAYS',
  projects: 'PROJECTS', experiments: 'EXPERIMENTS',
};
const statusLabels = {
  draft: '草稿', active: '活躍', stable: '穩定', archived: '歸檔', ongoing: '進行中', future: '未來',
};
const presentTypes = Array.from(new Set(nodes.map((node) => node.type)));
const presentStatuses = Array.from(new Set(nodes.map((node) => node.status)));
---

<section class="archive-atlas" data-archive-atlas>
  <script type="application/json" data-atlas-data set:html={JSON.stringify(nodes)} />

  <header class="atlas-status">
    <div><span class="status-dot"></span><strong>LIVE ARCHIVE / BUILD-TIME MDX</strong></div>
    <p>{nodes.length} 個公開對象；不包含 OBS-X、草稿和 future 占位內容。</p>
  </header>

  <div class="atlas-controls" aria-label="檔案地圖篩選">
    <label class="search-control">
      <span>搜索</span>
      <input type="search" data-filter-query placeholder="搜索標題、摘要、標籤或編號" autocomplete="off" />
    </label>
    <label>
      <span>內容類型</span>
      <select data-filter-type>
        <option value="all">全部類型</option>
        {presentTypes.map((type) => <option value={type}>{typeLabels[type]}</option>)}
      </select>
    </label>
    <label>
      <span>內容領域</span>
      <select data-filter-field>
        <option value="all">全部領域</option>
        {Object.entries(fieldLabels).map(([field, label]) => <option value={field}>{label}</option>)}
      </select>
    </label>
    <label>
      <span>狀態</span>
      <select data-filter-status>
        <option value="all">全部狀態</option>
        {presentStatuses.map((status) => <option value={status}>{statusLabels[status]}</option>)}
      </select>
    </label>
    <button type="button" data-reset-view>重置視圖</button>
  </div>

  <div class="atlas-workspace">
    <div class="atlas-stage" data-atlas-stage>
      <canvas data-atlas-canvas aria-label="可縮放的公開 Archive 時間地圖；下方提供等價鍵盤列表"></canvas>
      <div class="atlas-key" aria-hidden="true">
        {presentTypes.map((type) => <span><i data-type={type}></i>{type.toUpperCase()}</span>)}
      </div>
      <div class="zoom-controls" aria-label="地圖縮放">
        <button type="button" data-zoom-out aria-label="縮小地圖">−</button>
        <output data-zoom-output>100%</output>
        <button type="button" data-zoom-in aria-label="放大地圖">＋</button>
      </div>
      <p class="stage-help">滾輪縮放／拖動時間空間／點擊節點查看對象</p>
      <div class="empty-state" data-empty-state hidden>
        <strong>沒有符合條件的公開對象</strong>
        <p>重置篩選，或使用更寬的搜索關鍵詞。</p>
      </div>
    </div>

    <aside class="atlas-detail" data-atlas-detail aria-live="polite">
      <header class="detail-heading">
        <span>ARCHIVE OBJECT INSPECTOR</span>
        <p>節點資料與文章中明確指定的關聯</p>
      </header>
      <div class="detail-empty" data-detail-empty>
        <h2>選擇一個檔案節點</h2>
        <p>點選畫布中的節點後，這裡會顯示它的標題、摘要、發布時間、閱讀長度、分類與標籤。</p>
        <p class="detail-guide">畫布中的虛線只表示 Archive 文章 frontmatter 中 <code>related</code> 明確記錄的關聯，不推測內容之間的隱含關係。</p>
      </div>
      <div data-detail-content hidden>
        <div class="detail-meta"><span data-detail-id></span><span data-detail-type></span></div>
        <h2 data-detail-title></h2>
        <p class="detail-summary" data-detail-summary></p>
        <dl>
          <div><dt>發布</dt><dd data-detail-date></dd></div>
          <div><dt>更新</dt><dd data-detail-updated></dd></div>
          <div><dt>閱讀</dt><dd data-detail-reading></dd></div>
          <div><dt>狀態</dt><dd data-detail-status></dd></div>
          <div><dt>領域</dt><dd data-detail-field></dd></div>
        </dl>
        <div class="detail-tags" data-detail-tags></div>
        <div class="detail-related"><span>明確關聯 · 畫布虛線</span><p data-detail-related></p></div>
        <a class="detail-link" data-detail-link>進入 Archive Object →</a>
      </div>
    </aside>
  </div>

  <section class="accessible-results" aria-labelledby="atlas-results-title">
    <header>
      <div><span>ACCESSIBLE INDEX</span><h2 id="atlas-results-title">等價內容列表</h2></div>
      <output data-result-count>0 個公開對象</output>
    </header>
    <div class="result-list" data-result-list></div>
  </section>
</section>

<script>
  import type { ArchiveAtlasNode } from '../../lab/data/archive-atlas';

  const root = document.querySelector<HTMLElement>('[data-archive-atlas]:not([data-initialized])');
  if (root) {
    root.dataset.initialized = 'true';
    const nodes = JSON.parse(root.querySelector<HTMLScriptElement>('[data-atlas-data]')!.textContent ?? '[]') as ArchiveAtlasNode[];
    const canvas = root.querySelector<HTMLCanvasElement>('[data-atlas-canvas]')!;
    const stage = root.querySelector<HTMLElement>('[data-atlas-stage]')!;
    const context = canvas.getContext('2d');
    const queryInput = root.querySelector<HTMLInputElement>('[data-filter-query]')!;
    const typeSelect = root.querySelector<HTMLSelectElement>('[data-filter-type]')!;
    const fieldSelect = root.querySelector<HTMLSelectElement>('[data-filter-field]')!;
    const statusSelect = root.querySelector<HTMLSelectElement>('[data-filter-status]')!;
    const zoomOutput = root.querySelector<HTMLOutputElement>('[data-zoom-output]')!;
    const emptyState = root.querySelector<HTMLElement>('[data-empty-state]')!;
    const resultList = root.querySelector<HTMLElement>('[data-result-list]')!;
    const resultCount = root.querySelector<HTMLOutputElement>('[data-result-count]')!;
    const detailEmpty = root.querySelector<HTMLElement>('[data-detail-empty]')!;
    const detailContent = root.querySelector<HTMLElement>('[data-detail-content]')!;
    const controller = new AbortController();
    const signal = controller.signal;
    const url = new URL(location.href);

    const fields = ['research', 'systems', 'signals', 'essays', 'projects', 'experiments'];
    const fieldLabels: Record<string, string> = { research: 'RESEARCH', systems: 'SYSTEMS', signals: 'SIGNALS', essays: 'ESSAYS', projects: 'PROJECTS', experiments: 'EXPERIMENTS' };
    const typeLabels: Record<string, string> = { essay: '隨筆', research: '研究', system: '系統', signal: '信號', project: '項目', failure: '復盤', experiment: '實驗', journal: '記錄', unknown: '未知' };
    const statusLabels: Record<string, string> = { draft: '草稿', active: '活躍', stable: '穩定', archived: '歸檔', ongoing: '進行中', future: '未來' };
    const colors: Record<string, string> = { essay: '#c99b83', research: '#9baec9', system: '#77b2bd', signal: '#d0b66e', project: '#ae9acb', failure: '#c77f76', experiment: '#8db99c', journal: '#929fa4', unknown: '#69767a' };
    const supported = (select: HTMLSelectElement, value: string | null) => value && Array.from(select.options).some((option) => option.value === value) ? value : 'all';

    let filtered = [...nodes];
    let selectedId: string | null = url.searchParams.get('node');
    let zoom = Math.min(2.5, Math.max(1, Number(url.searchParams.get('zoom')) || 1));
    let pan = Math.min(0.45, Math.max(-0.45, Number(url.searchParams.get('pan')) || 0));
    let points: Array<{ node: ArchiveAtlasNode; x: number; y: number; radius: number }> = [];
    let dragging = false;
    let moved = false;
    let pointerStart = 0;
    let panStart = 0;
    let destroyed = false;

    queryInput.value = url.searchParams.get('q') ?? '';
    typeSelect.value = supported(typeSelect, url.searchParams.get('type'));
    fieldSelect.value = supported(fieldSelect, url.searchParams.get('field'));
    statusSelect.value = supported(statusSelect, url.searchParams.get('status'));

    const worker = typeof Worker === 'undefined' ? null : new Worker(new URL('../../lab/workers/archive-atlas.worker.ts', import.meta.url), { type: 'module' });
    const setText = (selector: string, value: string) => { root.querySelector<HTMLElement>(selector)!.textContent = value; };

    function explicitRelations(node: ArchiveAtlasNode) {
      return Array.from(new Set([
        ...node.related,
        ...nodes.filter((candidate) => candidate.related.includes(node.id)).map((candidate) => candidate.id),
      ])).filter((id) => nodes.some((candidate) => candidate.id === id));
    }

    function updateUrl() {
      const next = new URL(location.href);
      const values = { q: queryInput.value.trim(), type: typeSelect.value, field: fieldSelect.value, status: statusSelect.value, node: selectedId ?? '', zoom: zoom === 1 ? '' : zoom.toFixed(2), pan: Math.abs(pan) < 0.005 ? '' : pan.toFixed(3) };
      Object.entries(values).forEach(([key, value]) => value && value !== 'all' ? next.searchParams.set(key, value) : next.searchParams.delete(key));
      history.replaceState({}, '', next);
    }

    function localFilter() {
      const query = queryInput.value.trim().toLocaleLowerCase('zh-CN');
      return nodes
        .filter((node) => typeSelect.value === 'all' || node.type === typeSelect.value)
        .filter((node) => fieldSelect.value === 'all' || node.field === fieldSelect.value)
        .filter((node) => statusSelect.value === 'all' || node.status === statusSelect.value)
        .filter((node) => !query || [node.title, node.summary, node.objectId, node.field, ...node.tags].join(' ').toLocaleLowerCase('zh-CN').includes(query));
    }

    function requestFilter() {
      updateUrl();
      if (worker) worker.postMessage({ type: 'filter', nodes, query: queryInput.value, contentType: typeSelect.value, field: fieldSelect.value, status: statusSelect.value });
      else applyFiltered(localFilter());
    }

    function applyFiltered(next: ArchiveAtlasNode[]) {
      filtered = next;
      if (selectedId && !filtered.some((node) => node.id === selectedId)) selectedId = null;
      emptyState.hidden = filtered.length !== 0;
      renderList(); renderDetail(); draw(); updateUrl();
    }

    function resizeCanvas() {
      const scale = Math.min(devicePixelRatio, 1.5);
      const width = Math.max(1, Math.floor(stage.clientWidth * scale));
      const height = Math.max(1, Math.floor(stage.clientHeight * scale));
      if (canvas.width !== width || canvas.height !== height) { canvas.width = width; canvas.height = height; }
      return scale;
    }

    function positionFor(node: ArchiveAtlasNode, width: number, height: number, mobile: boolean) {
      const lane = Math.max(0, fields.indexOf(node.field));
      const transformed = (node.timePosition - 0.5) * zoom + 0.5 + pan;
      if (mobile) return { x: 52 + lane * ((width - 78) / (fields.length - 1)), y: 70 + transformed * (height - 140) };
      return { x: 105 + transformed * (width - 170), y: 92 + lane * ((height - 168) / (fields.length - 1)) };
    }

    function draw() {
      if (!context || destroyed) return;
      const scale = resizeCanvas();
      const width = canvas.width / scale;
      const height = canvas.height / scale;
      const mobile = width < 680;
      context.setTransform(scale, 0, 0, scale, 0, 0);
      context.clearRect(0, 0, width, height);
      context.fillStyle = '#071015'; context.fillRect(0, 0, width, height);
      context.font = '9px SFMono-Regular, Consolas, monospace'; context.textBaseline = 'middle';

      fields.forEach((field, index) => {
        context.strokeStyle = 'rgba(123,159,167,.15)'; context.lineWidth = 1; context.beginPath();
        if (mobile) {
          const x = 52 + index * ((width - 78) / (fields.length - 1));
          context.moveTo(x, 42); context.lineTo(x, height - 42); context.stroke();
          context.save(); context.translate(x, 27); context.rotate(-Math.PI / 2); context.fillStyle = '#6f848a'; context.fillText(fieldLabels[field], 0, 0); context.restore();
        } else {
          const y = 92 + index * ((height - 168) / (fields.length - 1));
          context.moveTo(92, y); context.lineTo(width - 32, y); context.stroke();
          context.fillStyle = '#6f848a'; context.fillText(fieldLabels[field], 12, y);
        }
      });

      const selected = nodes.find((node) => node.id === selectedId);
      if (selected) {
        const source = positionFor(selected, width, height, mobile);
        explicitRelations(selected).forEach((id) => {
          const targetNode = filtered.find((node) => node.id === id);
          if (!targetNode) return;
          const target = positionFor(targetNode, width, height, mobile);
          context.strokeStyle = 'rgba(213,180,111,.55)'; context.setLineDash([4, 5]); context.beginPath(); context.moveTo(source.x, source.y); context.lineTo(target.x, target.y); context.stroke(); context.setLineDash([]);
        });
      }

      points = filtered.map((node) => {
        const position = positionFor(node, width, height, mobile);
        const radius = 7 + node.readingWeight * 8;
        const isSelected = node.id === selectedId;
        const visible = position.x > -30 && position.x < width + 30 && position.y > -30 && position.y < height + 30;
        context.globalAlpha = visible ? 1 : 0;
        context.strokeStyle = isSelected ? '#ead8ae' : colors[node.type];
        context.fillStyle = isSelected ? 'rgba(234,216,174,.18)' : `${colors[node.type]}20`;
        context.lineWidth = isSelected || node.status === 'active' ? 2 : 1;
        context.setLineDash(node.status === 'archived' ? [3, 3] : node.status === 'ongoing' ? [1, 2] : []);
        context.beginPath(); context.arc(position.x, position.y, radius + 8, 0, Math.PI * 2); context.fill(); context.stroke(); context.setLineDash([]);
        context.fillStyle = colors[node.type]; context.beginPath(); context.arc(position.x, position.y, Math.max(3, radius * .38), 0, Math.PI * 2); context.fill();
        if (isSelected || zoom > 1.35) { context.fillStyle = '#d7e3e1'; context.font = '10px SFMono-Regular, Consolas, monospace'; context.fillText(node.title.length > 20 ? `${node.title.slice(0, 19)}…` : node.title, position.x + radius + 12, position.y - 2); }
        context.globalAlpha = 1;
        return { node, x: position.x, y: position.y, radius: radius + 12 };
      });

      const ordered = [...nodes].sort((a, b) => a.date.localeCompare(b.date));
      context.fillStyle = '#61757b'; context.font = '9px SFMono-Regular, Consolas, monospace';
      if (ordered.length) {
        if (mobile) { context.fillText(ordered[0].dateLabel, 8, 50); context.fillText(ordered.at(-1)!.dateLabel, 8, height - 24); }
        else { context.fillText(ordered[0].dateLabel, 92, height - 24); context.fillText(ordered.at(-1)!.dateLabel, width - 92, height - 24); }
      }
      zoomOutput.value = `${Math.round(zoom * 100)}%`;
    }

    function renderDetail() {
      const node = nodes.find((item) => item.id === selectedId);
      detailEmpty.hidden = Boolean(node); detailContent.hidden = !node;
      if (!node) return;
      setText('[data-detail-id]', node.objectId); setText('[data-detail-type]', typeLabels[node.type]);
      setText('[data-detail-title]', node.title); setText('[data-detail-summary]', node.summary);
      setText('[data-detail-date]', node.dateLabel); setText('[data-detail-updated]', node.updatedLabel ?? '未另行更新');
      setText('[data-detail-reading]', node.readingLabel); setText('[data-detail-status]', statusLabels[node.status]); setText('[data-detail-field]', fieldLabels[node.field]);
      const tags = root.querySelector<HTMLElement>('[data-detail-tags]')!;
      tags.replaceChildren(...node.tags.map((tag) => Object.assign(document.createElement('span'), { textContent: tag })));
      const relatedNames = explicitRelations(node).map((id) => nodes.find((candidate) => candidate.id === id)?.title).filter(Boolean);
      setText('[data-detail-related]', relatedNames.length ? relatedNames.join('／') : '沒有明確關聯');
      root.querySelector<HTMLAnchorElement>('[data-detail-link]')!.href = node.href;
    }

    function selectNode(id: string, scrollDetail = false) {
      selectedId = id; renderDetail(); renderList(); draw(); updateUrl();
      if (scrollDetail && matchMedia('(max-width: 820px)').matches) root.querySelector<HTMLElement>('[data-atlas-detail]')!.scrollIntoView({ block: 'start', behavior: matchMedia('(prefers-reduced-motion: reduce)').matches ? 'auto' : 'smooth' });
    }

    function renderList() {
      resultList.replaceChildren(); resultCount.value = `${filtered.length} 個公開對象`;
      filtered.forEach((node) => {
        const button = document.createElement('button'); button.type = 'button'; button.className = 'result-item'; button.dataset.selected = String(node.id === selectedId);
        const meta = document.createElement('span'); meta.textContent = `${node.objectId} / ${typeLabels[node.type]} / ${fieldLabels[node.field]}`;
        const title = document.createElement('strong'); title.textContent = node.title;
        const detail = document.createElement('small'); detail.textContent = `${node.dateLabel} · ${statusLabels[node.status]} · ${node.readingLabel}`;
        button.append(meta, title, detail); button.addEventListener('click', () => selectNode(node.id, true), { signal }); resultList.append(button);
      });
    }

    const resizeObserver = new ResizeObserver(draw); resizeObserver.observe(stage);
    worker?.addEventListener('message', (event) => { if (event.data?.type !== 'filtered') return; const ids = new Set<string>(event.data.ids); applyFiltered(nodes.filter((node) => ids.has(node.id))); }, { signal });
    [queryInput, typeSelect, fieldSelect, statusSelect].forEach((control) => control.addEventListener('input', requestFilter, { signal }));
    root.querySelector('[data-reset-view]')!.addEventListener('click', () => { queryInput.value = ''; typeSelect.value = 'all'; fieldSelect.value = 'all'; statusSelect.value = 'all'; selectedId = null; zoom = 1; pan = 0; requestFilter(); }, { signal });
    root.querySelector('[data-zoom-in]')!.addEventListener('click', () => { zoom = Math.min(2.5, zoom + .25); draw(); updateUrl(); }, { signal });
    root.querySelector('[data-zoom-out]')!.addEventListener('click', () => { zoom = Math.max(1, zoom - .25); if (zoom === 1) pan = 0; draw(); updateUrl(); }, { signal });
    canvas.addEventListener('wheel', (event) => { event.preventDefault(); zoom = Math.min(2.5, Math.max(1, zoom + (event.deltaY < 0 ? .15 : -.15))); if (zoom === 1) pan = 0; draw(); updateUrl(); }, { passive: false, signal });
    canvas.addEventListener('pointerdown', (event) => { dragging = true; moved = false; pointerStart = matchMedia('(max-width: 680px)').matches ? event.clientY : event.clientX; panStart = pan; canvas.setPointerCapture(event.pointerId); }, { signal });
    canvas.addEventListener('pointermove', (event) => { if (!dragging) return; const current = matchMedia('(max-width: 680px)').matches ? event.clientY : event.clientX; const size = matchMedia('(max-width: 680px)').matches ? canvas.clientHeight : canvas.clientWidth; const delta = (current - pointerStart) / Math.max(1, size); if (Math.abs(delta) > .008) moved = true; pan = Math.min(.45, Math.max(-.45, panStart + delta)); draw(); }, { signal });
    canvas.addEventListener('pointerup', (event) => { dragging = false; if (!moved) { const bounds = canvas.getBoundingClientRect(); const x = event.clientX - bounds.left; const y = event.clientY - bounds.top; const hit = [...points].reverse().find((point) => Math.hypot(point.x - x, point.y - y) <= point.radius); if (hit) selectNode(hit.node.id, true); } updateUrl(); }, { signal });

    const cleanup = () => { if (destroyed) return; destroyed = true; controller.abort(); worker?.terminate(); resizeObserver.disconnect(); delete root.dataset.initialized; };
    window.addEventListener('pagehide', cleanup, { once: true, signal }); document.addEventListener('astro:before-swap', cleanup, { once: true, signal });
    if (worker) requestFilter(); else applyFiltered(localFilter());
  }
</script>

<style>
  .archive-atlas { background: #071014; border: 1px solid #2b3b42; }
  .atlas-status { align-items: center; border-bottom: 1px solid #2b3b42; display: flex; gap: 2rem; justify-content: space-between; padding: .8rem 1rem; }
  .atlas-status > div { align-items: center; display: flex; gap: .6rem; }
  .atlas-status strong, .atlas-status p, label span, .atlas-controls button, .atlas-key, .zoom-controls, .stage-help, .detail-meta, .detail-related span, .accessible-results header span, .accessible-results output { font-family: var(--font-mono); font-size: .66rem; letter-spacing: .08em; }
  .atlas-status p { color: #82959b; margin: 0; } .status-dot { background: #7db8a0; border-radius: 50%; height: 6px; width: 6px; }
  .atlas-controls { background: #2b3b42; border-bottom: 1px solid #2b3b42; display: grid; gap: 1px; grid-template-columns: minmax(240px, 1.7fr) repeat(3, minmax(150px, .7fr)) auto; }
  .atlas-controls label { background: #071014; display: grid; gap: .35rem; padding: .7rem .8rem; } label span { color: #758990; }
  input, select, .atlas-controls button { background: #0a1419; border: 1px solid #2c4149; color: #dce8e6; min-height: 38px; padding: .5rem .65rem; width: 100%; } .atlas-controls button { width: auto; }
  .atlas-workspace { display: grid; grid-template-columns: minmax(0, 1fr) minmax(300px, .32fr); min-height: 720px; }
  .atlas-stage { min-height: 720px; overflow: hidden; position: relative; } canvas { cursor: grab; height: 100%; inset: 0; position: absolute; touch-action: none; width: 100%; } canvas:active { cursor: grabbing; }
  .atlas-key { display: flex; flex-wrap: wrap; gap: .8rem; left: 1rem; max-width: 70%; position: absolute; top: 1rem; }
  .atlas-key span { align-items: center; color: #82969c; display: flex; gap: .35rem; } .atlas-key i { background: #8fa2a8; border-radius: 50%; height: 6px; width: 6px; }
  .atlas-key i[data-type='essay'] { background:#c99b83 } .atlas-key i[data-type='research'] { background:#9baec9 } .atlas-key i[data-type='system'] { background:#77b2bd } .atlas-key i[data-type='signal'] { background:#d0b66e } .atlas-key i[data-type='project'] { background:#ae9acb } .atlas-key i[data-type='failure'] { background:#c77f76 } .atlas-key i[data-type='experiment'] { background:#8db99c }
  .zoom-controls { align-items: center; display: flex; position: absolute; right: 1rem; top: 1rem; } .zoom-controls button, .zoom-controls output { align-items: center; background: rgba(7,16,20,.9); border: 1px solid #2d4149; color: #d8e5e2; display: flex; height: 34px; justify-content: center; min-width: 40px; padding: 0 .6rem; } .zoom-controls output { border-inline: 0; min-width: 54px; }
  .stage-help { bottom: .8rem; color: #6f8389; left: 1rem; margin: 0; position: absolute; } .empty-state { left: 50%; position: absolute; text-align: center; top: 50%; transform: translate(-50%,-50%); } .empty-state p { color: #84969b; }
