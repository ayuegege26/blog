---
import LabLayout from '@layouts/LabLayout.astro';
---

<LabLayout title="NAS Observatory | Lab" description="周期更新的 NAS 数据观察。" section="NAS Observatory">
  <main class="section-page">
    <header>
      <p>LAB SECTION / 02</p>
      <h1>NAS Observatory</h1>
      <div class="section-copy">
        <strong>把真实系统从指标面板重新表达为具有关系和时间感的观察对象。</strong>
        <span>PUBLIC SNAPSHOT / HOURLY / READ ONLY</span>
      </div>
    </header>
    <a class="project" href="/lab/nas-observatory/constellation">
      <div class="project-index">NO–001</div>
      <div><span>FIXTURE AVAILABLE / GATEWAY PENDING</span><h2>NAS Constellation</h2><p>使用脱敏快照与聚合历史构成的公开服务星图。</p></div>
      <strong>查看 fixture →</strong>
    </a>
  </main>
</LabLayout>

<style>
  .section-page { padding: clamp(4rem, 9vw, 8rem) 0; }
  header > p, .section-copy span, .project span, .project-index, .project > strong { color: #78919b; font-family: var(--font-mono); font-size: 0.7rem; letter-spacing: 0.1em; }
  h1 { font-size: clamp(3.6rem, 9vw, 9rem); font-weight: 400; letter-spacing: -0.07em; line-height: 0.9; margin: 1rem 0 2.5rem; }
  .section-copy { border-top: 1px solid #26343a; display: flex; gap: 2rem; justify-content: space-between; padding-top: 1rem; }
  .section-copy strong { font-size: 1.05rem; font-weight: 400; }
  .project { align-items: center; border-bottom: 1px solid #26343a; border-top: 1px solid #26343a; display: grid; gap: 2rem; grid-template-columns: 90px minmax(0, 1fr) auto; margin-top: 7rem; padding: 2rem 0; }
  .project h2 { font-size: clamp(2rem, 5vw, 5rem); font-weight: 400; margin: 0.5rem 0; }
  .project p { color: #94a3a8; margin: 0; }
  .project:hover { background: rgba(124, 189, 198, 0.035); }
  @media (max-width: 700px) { .section-copy { flex-direction: column; } .project { grid-template-columns: 1fr; } }
</style>
