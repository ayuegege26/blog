---
import NasConstellation from '@components/lab/NasConstellation.astro';
import LabLayout from '@layouts/LabLayout.astro';

const gatewayMode = import.meta.env.PUBLIC_LAB_DATA_MODE === 'gateway';
---

<LabLayout title="NAS Constellation | NAS Observatory" description="使用脱敏快照与聚合历史构成的公开 NAS 服务星图。" section="NAS Observatory / NO–001">
  <main class="project-page">
    <header class="project-heading">
      <div><p>NAS OBSERVATORY / NO–001</p><h1>NAS Constellation</h1></div>
      <p>{gatewayMode ? '当前连接匿名只读 NAS Data Gateway；仅展示定期更新的公开聚合数据。' : '当前使用脱敏 fixture 验证数据契约和全部界面状态。'}</p>
    </header>
    <NasConstellation />
    <footer class="project-meta"><span>ANONYMOUS / READ ONLY</span><span>HOURLY SNAPSHOT / 2H STALE</span><a href="/lab/nas-observatory">返回 NAS Observatory</a></footer>
  </main>
</LabLayout>

<style>
  .project-page { padding: clamp(2rem, 5vw, 4rem) 0 2rem; }
  .project-heading { align-items: end; display: grid; gap: 2rem; grid-template-columns: minmax(0, 1.2fr) minmax(260px, 0.45fr); margin-bottom: 1.5rem; }
  .project-heading > div > p, .project-meta { color: #78919b; font-family: var(--font-mono); font-size: 0.68rem; letter-spacing: 0.1em; }
  h1 { font-size: clamp(3rem, 7vw, 6.5rem); font-weight: 400; letter-spacing: -0.06em; line-height: 0.9; margin: 0.7rem 0 0; }
  .project-heading > p { border-left: 1px solid #314148; color: #9aacb0; line-height: 1.8; margin: 0; padding-left: 1rem; }
  .project-meta { display: flex; flex-wrap: wrap; gap: 1rem 2rem; justify-content: space-between; padding-top: 1rem; }
  .project-meta a { color: #b7d4d4; }
  @media (max-width: 720px) { .project-heading { grid-template-columns: 1fr; } }
</style>
